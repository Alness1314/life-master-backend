<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Recordatorio de Pago</title>

    <style>
        /* 🌙 Dark mode soporte básico */
        @media (prefers-color-scheme: dark) {
            body {
                background-color: #1c1c1c !important;
            }
            .container {
                background-color: #2a2a2a !important;
                color: #e0e0e0 !important;
            }
            .box {
                background-color: #3a3a3a !important;
            }
            .text-muted {
                color: #bbbbbb !important;
            }
        }
    </style>
</head>

<body style="margin:0; padding:20px; background-color:#f4f6f8; font-family: Arial, sans-serif;">

    <!-- 🔹 Contenedor principal -->
    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center">

                <!-- 🔹 Card -->
                <table width="600" cellpadding="0" cellspacing="0" class="container"
                       style="background:#ffffff; padding:30px; border-radius:10px;">

                    <!-- 🔹 Header -->
                    <tr>
                        <td>
                            <table width="100%">
                                <tr>
                                    <!-- Título izquierda -->
                                    <td align="left" style="font-size:22px; font-weight:bold; color:#333;">
                                        Recordatorio de pago
                                    </td>

                                    <!-- Logo derecha REAL -->
                                    <td align="right">
                                        <img src="cid:logoApp" width="240" style="display:block;">
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- 🔹 Espacio -->
                    <tr><td height="20"></td></tr>

                    <!-- 🔹 Texto -->
                    <tr>
                        <td style="color:#555;">
                            Estimado(a) {{nombre}},
                        </td>
                    </tr>

                    <tr><td height="10"></td></tr>

                    <tr>
                        <td style="color:#555;">
                            Le recordamos que cuenta con un pago pendiente. A continuación se muestran los detalles:
                        </td>
                    </tr>

                    <!-- 🔹 Espacio -->
                    <tr><td height="20"></td></tr>

                    <!-- 🔹 Caja -->
                    <tr>
                        <td class="box" style="background:#f9fafb; padding:15px; border-radius:8px;">
                            <p><strong>Concepto:</strong> {{concepto}}</p>
                            <p><strong>Monto:</strong> ${{monto}}</p>
                            <p><strong>Fecha límite:</strong> {{fechaPago}}</p>
                        </td>
                    </tr>

                    <!-- 🔹 Espacio -->
                    <tr><td height="20"></td></tr>

                    <!-- 🔹 Aviso -->
                    <tr>
                        <td style="color:#d9534f; font-weight:bold;">
                            Evite cargos adicionales realizando su pago antes de la fecha límite.
                        </td>
                    </tr>

                    <tr><td height="10"></td></tr>

                    <!-- 🔹 Nota -->
                    <tr>
                        <td style="color:#555;">
                            Este recordatorio forma parte de su control personal de pagos dentro de la aplicación.
                        </td>
                    </tr>

                    <!-- 🔹 Línea -->
                    <tr><td height="25"></td></tr>
                    <tr>
                        <td style="border-top:1px solid #ddd;"></td>
                    </tr>
                    <tr><td height="15"></td></tr>

                    <!-- 🔹 Footer -->
                    <tr>
                        <td align="center" class="text-muted" style="font-size:12px; color:#888;">
                            Este es un correo automático generado por la aplicación, por favor no responda a este mensaje.
                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>
</html>